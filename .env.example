# ─────────────────────────────────────────────────────────────────
# ESPAÇO MIX — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA suba o arquivo .env para o GitHub.
#
# Na Vercel: Settings → Environment Variables (todas as variáveis de
# backend devem ser cadastradas lá também).
# ─────────────────────────────────────────────────────────────────

# ─── SUPABASE (frontend) ─────────────────────────────────────────
# URL do projeto Supabase
VITE_SUPABASE_URL=

# Chave pública (anon key) — pode ficar no frontend, é segura
VITE_SUPABASE_ANON_KEY=

# ─── BACKEND / SERVER ────────────────────────────────────────────
# URL do site em produção (usado para CORS e webhooks de pagamento)
APP_URL=

# Porta do servidor Express (dev)
PORT=3000

# ─── PAGAMENTO ───────────────────────────────────────────────────
# Qual gateway usar: mercadopago | disabled
PAYMENT_PROVIDER=mercadopago

# Mercado Pago — obter em: https://www.mercadopago.com.br/developers
# A Orders API (/v1/orders) NÃO aceita credenciais TEST-. Para sandbox use as
# credenciais de PRODUÇÃO (APP_USR-) de um VENDEDOR DE TESTE; em produção, as
# credenciais de produção da conta real.
MERCADOPAGO_ACCESS_TOKEN=

# Public Key do Mercado Pago (frontend tokenizar cartões) — do mesmo vendedor
VITE_MERCADOPAGO_PUBLIC_KEY=

# Secret de assinatura do webhook do Mercado Pago.
# Obter ao cadastrar o webhook no painel MP:
#   Suas integrações → (sua aplicação) → Webhooks → Configurar notificações
#   URL: https://<seu-domínio>/api/webhook/mercadopago  (evento: Pagamentos)
#   Copie a "Assinatura secreta" exibida após salvar.
# Sem este valor o webhook aceita notificações SEM validar a assinatura.
MERCADOPAGO_WEBHOOK_SECRET=

# ─── SPLIT DE PAGAMENTOS (Marketplace) ───────────────────────────
# O DESENVOLVEDOR é o marketplace (recebe a comissão) e o DONO do site é o
# vendedor (recebe o líquido). O dono conecta a conta MP dele via OAuth no
# painel admin ("Conectar Mercado Pago"). As orders passam a ser criadas com
# o token do vendedor + marketplace_fee — só assim o MP aceita o split.
#
# Credenciais da APLICAÇÃO MARKETPLACE (conta MP do desenvolvedor):
#   Suas integrações → (sua aplicação) → Credenciais de produção / OAuth.
# A redirect_uri abaixo precisa estar cadastrada IGUAL no painel da aplicação.
MP_MARKETPLACE_CLIENT_ID=
MP_MARKETPLACE_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=https://<seu-domínio>/api/mp/oauth/callback

# Comissão do desenvolvedor (controlada SÓ por aqui — o dono não altera no painel):
#   MARKETPLACE_FEE_TYPE  = percentage | fixed
#   MARKETPLACE_FEE_VALUE = 10  (=10% se percentage)  ou  2.00  (=R$ 2,00 se fixed)
# Se não definidas, cai na "Taxa da plataforma" do system_config (legado).
MARKETPLACE_FEE_TYPE=percentage
MARKETPLACE_FEE_VALUE=10

# ─── SUPABASE SERVICE ROLE (APENAS no servidor/backend) ──────────
# ⚠️ NUNCA use no frontend — tem acesso total ao banco (bypassa RLS)
# Obter em: Supabase Console → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ─── CONEXÃO DIRETA AO POSTGRES (DDL/migrações — APENAS backend) ─
# ⚠️ Contém a senha do banco — nunca expor no frontend.
# Use o TRANSACTION POOLER (porta 6543); a porta 5432 e o host direto
# não funcionam neste projeto.
# Formato: postgresql://postgres.<ref>:<senha>@aws-X-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# ─── CRIPTOGRAFIA DE DADOS SENSÍVEIS (APENAS no servidor) ────────
# ⚠️ NUNCA use com prefixo VITE_ — nunca deve ir ao frontend
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ter exatamente 64 caracteres hexadecimais.
ENCRYPTION_KEY=

# Dev TOTP (somente backend — nunca usar prefixo VITE_)
DEV_TOTP=

# ─── EMAIL (Resend) ──────────────────────────────────────────────
# Obter em: https://resend.com → API Keys (plano gratuito: 3.000/mês)
# Alternativa: SMTP via SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASSWORD,
# ou configurar o provedor pelo painel admin (fica criptografado no banco).
RESEND_API_KEY=

# Remetente (opcional — sobrepõe a config do painel)
# Em PRODUÇÃO é OBRIGATÓRIO usar um domínio VERIFICADO no Resend (SPF/DKIM/DMARC);
# sem EMAIL_SENDER_ADDRESS o envio falha (não usamos o domínio de teste em prod).
# EMAIL_SENDER_NAME=Espaço Mix
# EMAIL_SENDER_ADDRESS=contato@espacomix.com.br

# Destinatário das mensagens do formulário de contato (opcional).
# Precedência: system_config.contact_email → support_email → CONTACT_EMAIL → EMAIL_SENDER_ADDRESS.
# Padronize num único endereço (ex.: contato@espacomix.com.br).
# CONTACT_EMAIL=contato@espacomix.com.br

# Chave secreta para o endpoint de lembretes (/api/email/send-reminders)
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=
